# 高德地图 API
VITE_AMAP_KEY=your-amap-key-here

# AI Backend (File Bridge Architecture)
# Options: mimo | codebuddy | qwen | deepseek
VITE_AI_PROVIDER=mimo

# Session directory (relative to project root)
VITE_SESSIONS_DIR=sessions

# Polling interval (ms) - only active when waiting for AI response
VITE_POLL_INTERVAL=1000

# AI response timeout (ms)
VITE_AI_TIMEOUT=30000
